{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MultiRoblox",
  "version": "1.1.4",
  "identifier": "com.multiroblox.client",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "MultiRoblox",
        "width": 980,
        "height": 760,
        "minWidth": 945,
        "minHeight": 755,
        "decorations": false,
        "transparent": false,
        "backgroundColor": "#0e0e10",
        "visible": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English"]
      }
    },
    "resources": ["resources/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
